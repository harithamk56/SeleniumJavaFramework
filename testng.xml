<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Full_Suite" parallel="classes" thread-count="2">

    <!-- Normal test (no parameters) -->
    <test name="LaunchURL_Test">
        <classes>
            <class name="First.Project.LaunchURL_Test"/>
        </classes>
    </test>

    <!-- Chrome run -->
    <test name="Chrome - ParallelTest">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="First.Project.paralleltest"/>
        </classes>
    </test>

    <!-- Edge run -->
    <test name="Edge - ParallelTest">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="First.Project.paralleltest"/>
        </classes>
    </test>

</suite>